---
import type { CategoryMeta } from '@/data/categories';

interface Props {
  category: CategoryMeta;
  essayCount?: number;
}

const { category, essayCount = 0 } = Astro.props;
---

<article class="card-surface flex h-full flex-col">
  <h3 class="font-serif text-lg font-semibold text-forest">
    <a href={`/essays/?category=${category.slug}`}>{category.label}</a>
  </h3>
  <p class="mt-2 text-sm italic text-ink-muted">{category.question}</p>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-muted">{category.description}</p>
  {
    essayCount > 0 && (
      <p class="mt-4 text-xs font-medium text-forest">{essayCount} published · more coming</p>
    )
  }
</article>
