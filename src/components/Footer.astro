---
import { site } from '@/lib/site';
import { currentIssue } from '@/data/magazine';
import { support } from '@/data/support';

const year = new Date().getFullYear();
---

<footer class="mt-10 border-t-2 border-forest/10 bg-paper-deep/50">
  <div class="page-shell py-8 sm:py-9">
    <div class="mx-auto max-w-narrow text-center">
      <p class="font-display text-lg font-semibold text-ink">{site.magazineName}</p>
      <p class="folio mt-2">{currentIssue.label} · {currentIssue.monthYear}</p>
      <p class="mt-2 text-sm leading-relaxed text-ink-muted">{site.tagline}</p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-ink-faint">
        <a href="/issues/" class="hover:text-forest">Issues</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/essays/" class="hover:text-forest">Essays</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/lexicon/" class="hover:text-forest">Lexicon</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/research/" class="hover:text-forest">Research</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/masthead/" class="hover:text-forest">Masthead</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/press/" class="hover:text-forest">Press</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/editorial-policy/" class="hover:text-forest">Policy</a>
        <span class="ornament" aria-hidden="true">·</span>
        <a href="/privacy/" class="hover:text-forest">Privacy</a>
      </div>
      <p class="mt-4 text-xs leading-relaxed text-ink-faint">
        <a
          href={support.url}
          class="text-ink-muted hover:text-forest"
          target="_blank"
          rel="noopener noreferrer"
        >
          {support.copy.footer.link}
        </a>
        <span class="mx-2 ornament" aria-hidden="true">·</span>
        {support.copy.footer.sub}
      </p>
      <p class="folio mt-5">
        © {year} {site.author} · NLUCloud Press
      </p>
    </div>
  </div>
</footer>
