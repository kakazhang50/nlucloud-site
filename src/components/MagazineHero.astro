---
import type { MagazineIssue } from '@/data/issues';
import { issueCoverPath } from '@/lib/covers';
import type { EssayEntry } from '@/lib/issues';

interface Props {
  issue: MagazineIssue;
  essay?: EssayEntry;
}

const { issue, essay } = Astro.props;
const cover = issueCoverPath(issue.number);
const issueHref = `/issues/${String(issue.number).padStart(2, '0')}/`;
---

<section class="magazine-hero" aria-label="Current issue">
  <div class="magazine-hero-grid">
    <div class="magazine-hero-cover">
      <a href={issueHref} class="magazine-hero-cover-link">
        <img
          src={cover}
          alt={`${issue.label}: ${issue.title}`}
          width="800"
          height="1200"
          class="magazine-hero-cover-img"
          loading="eager"
          decoding="async"
        />
      </a>
      <p class="magazine-hero-folio">
        <span class="folio">{issue.label}</span>
        <span class="ornament mx-2" aria-hidden="true">·</span>
        <span>{issue.monthYear}</span>
      </p>
    </div>

    <div class="magazine-hero-text">
      <p class="folio text-accent-rust">Current Issue</p>
      <h2 class="magazine-hero-title">
        <a href={issueHref}>{issue.title}</a>
      </h2>
      <p class="magazine-hero-theme">{issue.theme}</p>

      <aside class="editor-lede magazine-hero-lede" aria-label="Editor's note">
        <p class="editor-lede-kicker">In this issue</p>
        <p class="editor-lede-text">{issue.editorLede}</p>
      </aside>

      {
        essay ? (
          <div class="magazine-hero-essay">
            <p class="folio mb-2">Cover Essay</p>
            <h3 class="font-serif text-xl font-semibold text-ink sm:text-2xl">
              <a href={`/essays/${essay.slug}/`} class="hover:text-forest">
                {essay.data.title}
              </a>
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted">{essay.data.description}</p>
            <a href={`/essays/${essay.slug}/`} class="cover-story-cta mt-5 inline-block">
              Read cover essay
            </a>
          </div>
        ) : (
          <div class="magazine-hero-essay">
            <p class="folio mb-2">Cover Essay · Forthcoming</p>
            <h3 class="font-serif text-xl font-semibold text-ink">{issue.coverEssayTitle}</h3>
            <p class="mt-2 text-sm text-ink-muted">Expected {issue.monthYear}.</p>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .magazine-hero {
    border-bottom: 1px solid #d8d0c4;
    padding-bottom: 2rem;
    margin-bottom: 0.5rem;
  }

  .magazine-hero-grid {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .magazine-hero-grid {
      grid-template-columns: minmax(12rem, 16rem) 1fr;
      gap: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .magazine-hero-grid {
      grid-template-columns: minmax(14rem, 18rem) 1fr;
      gap: 3rem;
    }
  }

  .magazine-hero-cover-link {
    display: block;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .magazine-hero-cover-link:hover {
    transform: translateY(-3px);
  }

  .magazine-hero-cover-img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid #d8d0c4;
    box-shadow:
      0 2px 4px rgba(26, 24, 22, 0.08),
      0 16px 48px rgba(21, 41, 33, 0.16);
  }

  .magazine-hero-folio {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.6875rem;
    color: #8a847c;
  }

  .magazine-hero-title {
    margin-top: 0.5rem;
    font-family: Fraunces, Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #1a1816;
  }

  @media (min-width: 640px) {
    .magazine-hero-title {
      font-size: 2.25rem;
    }
  }

  .magazine-hero-title a {
    color: inherit;
    transition: color 0.15s;
  }

  .magazine-hero-title a:hover {
    color: #1e3a2f;
  }

  .magazine-hero-theme {
    margin-top: 0.75rem;
    font-family: Newsreader, Georgia, serif;
    font-size: 1.0625rem;
    font-style: italic;
    line-height: 1.55;
    color: #5c5752;
  }

  .magazine-hero-lede {
    margin-top: 1.25rem;
  }

  .magazine-hero-essay {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #d8d0c4;
  }
</style>
