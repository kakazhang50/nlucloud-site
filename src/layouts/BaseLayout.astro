---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';
import { site, pageTitle } from '@/lib/site';
import {
  articleJsonLd,
  breadcrumbJsonLd,
  buildJsonLdGraph,
  type ArticleSchemaInput,
  type BreadcrumbItem,
} from '@/lib/schema';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  breadcrumbs?: BreadcrumbItem[];
  article?: Omit<ArticleSchemaInput, 'url' | 'siteUrl'>;
  extraSchema?: Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  ogType = 'website',
  breadcrumbs,
  article,
  extraSchema = [],
  noindex = false,
} = Astro.props;

const fullTitle = pageTitle(title);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? `https://${site.domain}`;
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site).href;

const schemaNodes: Record<string, unknown>[] = [...extraSchema];
if (breadcrumbs?.length) {
  schemaNodes.push(breadcrumbJsonLd(breadcrumbs, siteUrl, canonicalUrl));
}
if (article) {
  schemaNodes.push(
    articleJsonLd({
      ...article,
      url: canonicalUrl,
      siteUrl,
    }),
  );
}

const jsonLd = buildJsonLdGraph(siteUrl, canonicalUrl, schemaNodes);
const cfToken = site.cloudflareWebAnalyticsToken?.trim();
const robotsContent = noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#1E3A2F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM site context" />
    <link rel="alternate" type="text/plain" href="/llms-full.txt" title="Full LLM site context" />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <title>{fullTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {
      cfToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cfToken}"}`}
        />
      )
    }
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
