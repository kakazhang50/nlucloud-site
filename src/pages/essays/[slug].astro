---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ColumnMark from '@/components/ColumnMark.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import SupportBlock from '@/components/SupportBlock.astro';
import SubscribeBlock from '@/components/SubscribeBlock.astro';
import { getCategoryMeta } from '@/data/categories';
import { getResearchPaper } from '@/lib/content';
import { issuePath } from '@/data/issues';
import { essaySourceAttribution } from '@/lib/editorial';
import { getLexiconTitles } from '@/lib/lexicon';
import { site } from '@/lib/site';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => data.status === 'published');
  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
const cat = getCategoryMeta(essay.data.category);
const paper = await getResearchPaper(essay.data.sourcePaper);
const lexiconTitles = essay.data.frameworks?.length
  ? await getLexiconTitles(essay.data.frameworks)
  : new Map<string, string>();
---

<BaseLayout
  title={essay.data.title}
  description={essay.data.description}
  ogType="article"
  breadcrumbs={[
    { name: 'Essays', path: '/essays/' },
    { name: essay.data.title, path: `/essays/${essay.slug}/` },
  ]}
  article={{
    headline: essay.data.title,
    description: essay.data.description,
    datePublished: essay.data.pubDate.toISOString(),
  }}
>
  <article class="py-8 sm:py-10">
    <header class="article-header px-5">
      <ColumnMark accent={cat.accent} label={cat.label} class="centered" />
      {
        essay.data.issueNumber && essay.data.issueRole === 'cover' && (
          <p class="mt-3 text-center">
            <a
              href={issuePath(essay.data.issueNumber)}
              class="folio text-ink-muted hover:text-forest"
            >
              Issue {String(essay.data.issueNumber).padStart(2, '0')} · Cover Essay
            </a>
          </p>
        )
      }
      <h1 class="hero-title mt-4">{essay.data.title}</h1>
      <p class="deck mx-auto mt-4 max-w-prose">{essay.data.description}</p>
      <div class="mt-5 flex justify-center">
        <AuthorByline date={essay.data.pubDate} />
      </div>
      <div class="mx-auto mt-6 max-w-xs border-t border-line" aria-hidden="true"></div>
    </header>

    <div class="page-narrow mt-8 sm:mt-9">
      <div class="prose-nlu">
        <Content />
      </div>

      <footer class="source-note">
        <p class="folio mb-3">Source</p>
        {
          paper ? (
            <>
              <p class="text-sm leading-relaxed text-ink-soft">
                {essaySourceAttribution(
                  paper.data.title,
                  essay.data.sourceSection,
                )}
              </p>
              <p class="mt-3">
                <a href={`/research/${paper.slug}/`} class="link-editorial text-sm">
                  Research page on {site.siteName}
                </a>
                <span class="mx-2 text-ink-muted" aria-hidden="true">·</span>
                <a
                  href={paper.data.ssrnUrl}
                  class="link-editorial text-sm"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Read the full paper on SSRN
                </a>
              </p>
            </>
          ) : (
            <p class="text-sm text-ink-soft">{essay.data.sourcePaper}</p>
          )
        }
        {
          essay.data.frameworks?.length ? (
            <p class="mt-4 text-xs">
              Lexicon:{' '}
              {essay.data.frameworks.map((fw, i) => (
                <>
                  {i > 0 && ', '}
                  <a href={`/lexicon/${fw}/`} class="text-forest hover:underline">
                    {lexiconTitles.get(fw)}
                  </a>
                </>
              ))}
            </p>
          ) : null
        }
      </footer>

      <SupportBlock variant="essay" />

      <SubscribeBlock variant="essay" />
    </div>
  </article>
</BaseLayout>
