---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SubscribeBlock from '@/components/SubscribeBlock.astro';
---

<BaseLayout
  title="Annual Review 2026"
  description="NLUCloud AI & Society Annual Review 2026 — forthcoming late 2026."
  breadcrumbs={[{ name: 'Annual Review', path: '/annual-review/' }]}
>
  <div class="page-shell py-8 sm:py-10">
    <div class="page-main">
      <p class="folio mb-2">NLUCloud Press</p>
      <h1 class="font-display text-2xl font-semibold text-ink sm:text-3xl">
        NLUCloud AI &amp; Society Annual Review 2026
      </h1>
      <p class="deck mt-4 max-w-prose">Forthcoming · Late 2026</p>

      <div class="prose-nlu mt-8">
        <p>
          The Annual Review synthesizes a year of cover essays, lexicon entries, and working-paper
          research into one formal publication. Free executive summary; full PDF edition for
          purchase.
        </p>

        <h2>Contents</h2>
        <ol>
          <li>Editor's Preface</li>
          <li>Executive Summary <em>(free)</em></li>
          <li>The Year in AI and Society</li>
          <li>AI and Education</li>
          <li>AI and Knowledge Production</li>
          <li>Judgment, Waiting, and Latency</li>
          <li>Human–AI Representation</li>
          <li>Creative Motivation in the Generative Age</li>
          <li>Key Concepts of the Year</li>
          <li>Risks and Open Questions</li>
          <li>Outlook for 2027</li>
        </ol>

        <h2>Availability</h2>
        <p>
          <strong>Free:</strong> executive summary, table of contents, and lexicon highlights.<br />
          <strong>Paid:</strong> full PDF, charts appendix, professional edition.
        </p>
        <p class="text-sm text-ink-muted">
          Details and pre-order information will be announced here. See{' '}
          <a href="/issues/">Issues</a> for the monthly cover essay series.
        </p>

        <SubscribeBlock variant="annualReview" />
      </div>
    </div>
  </div>
</BaseLayout>
