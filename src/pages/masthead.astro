---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';
---

<BaseLayout
  title="Masthead"
  description="Publication information for NLUCloud AI & Society Review."
  breadcrumbs={[{ name: 'Masthead', path: '/masthead/' }]}
>
  <div class="page-shell py-8 sm:py-10">
    <div class="page-main">
      <p class="folio mb-4">Masthead</p>
      <div class="prose-nlu">
        <h2>Publication</h2>
        <p><strong>{site.magazineName}</strong></p>
        <p>{site.description}</p>

        <h2>Editor-in-Chief</h2>
        <p>
          <strong>{site.author}</strong><br />
          <a href={site.orcidUrl}>ORCID</a> · <a href={site.ssrnAuthorUrl}>SSRN</a>
        </p>

        <h2>Publisher</h2>
        <p><strong>NLUCloud Press</strong></p>

        <h2>Format</h2>
        <p>
          One cover essay per issue — long-form, English, for a general readership. Each issue
          draws on published research, especially working papers on{' '}
          <a href="/research/">SSRN</a>. A <a href="/lexicon/">Lexicon</a> of named concepts
          accompanies the series.
        </p>

        <h2>Independence</h2>
        <p>
          {site.magazineName} is an independent publication. It is not affiliated with a
          university, government body, or peer-reviewed journal. Cover essays are editorial
          interpretations; the underlying research papers remain the authoritative academic
          sources.
        </p>

        <h2>Web edition</h2>
        <p>
          <a href="https://nlucloud.com/">nlucloud.com</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
