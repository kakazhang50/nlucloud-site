---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SupportBlock from '@/components/SupportBlock.astro';
import { site } from '@/lib/site';
---

<BaseLayout title="About" breadcrumbs={[{ name: 'About', path: '/about/' }]}>
  <div class="page-shell py-4 sm:py-5">
    <div class="page-main">
      <p class="folio mb-4">About</p>
      <div class="prose-nlu">
        <p>{site.description}</p>

        <h2>What we publish</h2>
        <p>
          Each month, <strong>{site.magazineName}</strong> releases one cover essay — a
          long-form argument on AI and human life, written for readers outside academia. The{' '}
          <a href="/lexicon/">Lexicon</a> defines the concepts behind the essays. The{' '}
          <a href="/research/">Research</a> section indexes the underlying SSRN working papers.
        </p>

        <h2>Who reads it</h2>
        <p>
          Educators, researchers, policy thinkers, and anyone trying to understand what changes
          when AI becomes cheap — not only what it can generate, but what becomes scarce on the
          human side: judgment, waiting, representation, learning design, creative motive.
        </p>

        <h2>Editor</h2>
        <p>
          <strong>{site.author}</strong>, Editor-in-Chief<br />
          <a href={`mailto:${site.authorEmail}`}>{site.authorEmail}</a><br />
          <a href={site.orcidUrl}>ORCID</a> · <a href={site.ssrnAuthorUrl}>SSRN</a>
        </p>

        <SupportBlock variant="about" />

        <p>
          <a href="/masthead/">Masthead</a> · <a href="/editorial-policy/">Editorial policy</a> ·{' '}
          <a href="/press/">NLUCloud Press</a> · <a href="/annual-review/">Annual Review 2026</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
