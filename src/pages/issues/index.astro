---
import BaseLayout from '@/layouts/BaseLayout.astro';
import IssueCard from '@/components/IssueCard.astro';
import { site } from '@/lib/site';
import { siteIssues } from '@/data/issues';
import { getCoverEssayForIssue } from '@/lib/issues';

const rows = await Promise.all(
  siteIssues.map(async (issue) => ({
    issue,
    essay: await getCoverEssayForIssue(issue),
  })),
);
---

<BaseLayout
  title="Issues"
  description={`${site.magazineName} — one cover essay per issue.`}
  breadcrumbs={[{ name: 'Issues', path: '/issues/' }]}
>
  <div class="page-shell py-8 sm:py-10">
    <div class="page-main">
      <p class="folio mb-2">Issues</p>
      <p class="mb-8 max-w-prose text-sm leading-relaxed text-ink-muted">
        One cover essay per issue — a long-form editorial translation of published research,
        published monthly from January 2026.
      </p>

      <div class="issue-shelf-grid">
        {rows.map(({ issue, essay }) => (
          <IssueCard issue={issue} essay={essay} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .issue-shelf-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 1.25rem;
  }

  @media (min-width: 640px) {
    .issue-shelf-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem 1.5rem;
    }
  }
</style>
