---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/lib/site';
import { siteIssues, issuePath } from '@/data/issues';
import { getCoverEssayForIssue } from '@/lib/issues';

const rows = await Promise.all(
  siteIssues.map(async (issue) => ({
    issue,
    essay: await getCoverEssayForIssue(issue),
  })),
);
---

<BaseLayout
  title="Issues"
  description={`${site.magazineName} — one cover essay per issue.`}
  breadcrumbs={[{ name: 'Issues', path: '/issues/' }]}
>
  <div class="page-shell py-8 sm:py-10">
    <div class="page-main">
      <p class="folio mb-2">Issues</p>
      <p class="mb-8 max-w-prose text-sm leading-relaxed text-ink-muted">
        Each issue features one cover essay — a long-form editorial translation of published
        research, written for a general readership.
      </p>

      <div class="divide-y divide-line border-t border-line">
        {
          rows.map(({ issue, essay }) => (
            <article class="py-5">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <a href={issuePath(issue.number)} class="folio hover:text-forest">
                  {issue.label}
                </a>
                <span class="text-xs text-ink-faint">{issue.monthYear}</span>
              </div>
              <h2 class="mt-2 font-display text-xl font-semibold text-ink">
                <a href={issuePath(issue.number)} class="hover:text-forest">
                  {issue.title}
                </a>
              </h2>
              <p class="mt-2 text-sm text-ink-muted">{issue.theme}</p>
              <p class="mt-3 font-serif text-base text-ink-soft">
                {essay ? (
                  <a href={`/essays/${essay.slug}/`} class="hover:text-forest">
                    → {issue.coverEssayTitle}
                  </a>
                ) : (
                  <span class="text-ink-muted">Forthcoming: {issue.coverEssayTitle}</span>
                )}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
