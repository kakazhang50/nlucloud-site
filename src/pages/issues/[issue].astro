---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CoverStory from '@/components/CoverStory.astro';
import IssueCover from '@/components/IssueCover.astro';
import ColumnMark from '@/components/ColumnMark.astro';
import type { EssayCategory } from '@/content/config';
import { getCategoryMeta } from '@/data/categories';
import { siteIssues, issuePath } from '@/data/issues';
import { getResearchPaper } from '@/lib/content';
import { getLexiconTitles } from '@/lib/lexicon';
import { resolveIssuePage } from '@/lib/issues';

export async function getStaticPaths() {
  return siteIssues.map((issue) => ({
    params: { issue: String(issue.number).padStart(2, '0') },
  }));
}

const issueNum = parseInt(Astro.params.issue ?? '0', 10);
const { issue, essay } = await resolveIssuePage(issueNum);
const cat = getCategoryMeta(issue.category as EssayCategory);
const paper = issue.sourcePaper ? await getResearchPaper(issue.sourcePaper) : undefined;
const lexiconTitles = await getLexiconTitles(issue.lexiconSlugs);
const coverImage = issue.number === 1 ? '/covers/issue-01-cover.png' : undefined;
---

<BaseLayout
  title={`${issue.label}: ${issue.title}`}
  description={issue.theme}
  ogImage={coverImage}
  breadcrumbs={[
    { name: 'Issues', path: '/issues/' },
    { name: issue.label, path: issuePath(issue.number) },
  ]}
>
  <div class="issue-band">
    <div class="page-shell">
      <p class="issue-band-text">
        <span class="issue-band-label">{issue.label}</span>
        <span class="ornament mx-2" aria-hidden="true">·</span>
        <span>{issue.monthYear}</span>
        <span class="ornament mx-2" aria-hidden="true">·</span>
        <span class="issue-band-theme">{issue.title}</span>
      </p>
    </div>
  </div>

  <div class="page-shell pb-8 pt-6 sm:pb-10 sm:pt-8">
    <div class="page-main space-y-8">
      {coverImage && (
        <div class="issue-cover-hero">
          <IssueCover issue={issue} image={coverImage} priority />
        </div>
      )}

      <aside class="editor-lede" aria-label="Editor's note for this issue">
        <p class="editor-lede-kicker">In this issue</p>
        <p class="editor-lede-text">{issue.editorLede}</p>
      </aside>

      {essay ? (
        <CoverStory essay={essay} issue={issue} />
      ) : (
        <article class="cover-story">
          <div class:list={['cover-story-inner', `cover-story-accent-${cat.accent}`]}>
            <p class="cover-story-folio">
              {issue.label}
              <span class="ornament mx-2" aria-hidden="true">—</span>
              Cover Essay · Forthcoming
            </p>
            <ColumnMark accent={cat.accent} label={cat.label} class="mt-4" />
            <h2 class="cover-story-title mt-3">{issue.coverEssayTitle}</h2>
            <p class="cover-story-deck mt-3">{issue.theme}</p>
            <p class="mt-5 text-sm text-ink-muted">Expected {issue.monthYear}.</p>
          </div>
        </article>
      )}

      {
        paper && (
          <section class="section-block">
            <p class="folio mb-3">Source research</p>
            <p class="text-sm leading-relaxed text-ink-soft">
              <a href={`/research/${paper.slug}/`} class="font-serif text-ink hover:text-forest">
                {paper.data.title}
              </a>
              {issue.ssrnId && (
                <span class="text-ink-faint">
                  {' '}
                  · SSRN {issue.ssrnId}
                </span>
              )}
            </p>
          </section>
        )
      }

      {
        issue.lexiconSlugs.length > 0 && (
          <section class="section-block">
            <div class="section-kicker">
              <h2 class="folio">Lexicon entries</h2>
              <a href="/lexicon/" class="link-editorial text-xs">Full lexicon</a>
            </div>
            <ul class="mt-3 space-y-2 text-sm">
              {issue.lexiconSlugs.map((slug) => (
                <li>
                  <a href={`/lexicon/${slug}/`} class="link-editorial">
                    {lexiconTitles.get(slug)}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </div>
</BaseLayout>
