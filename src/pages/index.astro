---
import BaseLayout from '@/layouts/BaseLayout.astro';
import IssueBand from '@/components/IssueBand.astro';
import EditorLede from '@/components/EditorLede.astro';
import CoverStory from '@/components/CoverStory.astro';
import EssayFeedItem from '@/components/EssayFeedItem.astro';
import SectionNav from '@/components/SectionNav.astro';
import { site } from '@/lib/site';
import { getPublishedEssays, getPublishedEditorNotes } from '@/lib/content';
import { formatDate } from '@/lib/site';

const [essays, notes] = await Promise.all([
  getPublishedEssays(),
  getPublishedEditorNotes(),
]);

const [lead, ...rest] = essays;
---

<BaseLayout description={site.description}>
  <IssueBand />

  <div class="page-shell pb-6 pt-5 sm:pb-8 sm:pt-6">
    <div class="page-main space-y-6">
      <EditorLede />

      {lead && <CoverStory essay={lead} />}

      {
        (rest.length > 0 || essays.length > 0) && (
          <section>
            <div class="section-kicker">
              <h2 class="folio">Also in this issue</h2>
              <a href="/essays/" class="link-editorial text-xs">All essays</a>
            </div>
            <SectionNav variant="compact" showAll={false} />
            {
              rest.length > 0 ? (
                <div class="mt-4">
                  {rest.map((essay) => (
                    <EssayFeedItem essay={essay} />
                  ))}
                </div>
              ) : (
                <p class="mt-4 text-sm text-ink-muted">
                  More essays from the
                  <a href="/research/" class="link-editorial"> research archive</a> are forthcoming.
                </p>
              )
            }
          </section>
        )
      }

      {
        notes.length > 0 && (
          <section class="section-block">
            <div class="section-kicker">
              <h2 class="folio">Editor's Notes</h2>
              <a href="/editors-notes/" class="link-editorial text-xs">All notes</a>
            </div>
            {
              notes.slice(0, 2).map((note) => (
                <article class="feed-item">
                  <h3 class="feed-title">
                    <a href={`/editors-notes/${note.slug}/`}>{note.data.title}</a>
                  </h3>
                  <p class="mt-1.5 text-sm text-ink-muted">{note.data.description}</p>
                  <p class="feed-meta">{formatDate(note.data.pubDate)}</p>
                </article>
              ))
            }
          </section>
        )
      }
    </div>
  </div>
</BaseLayout>
