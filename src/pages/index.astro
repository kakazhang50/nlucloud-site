---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MagazineHero from '@/components/MagazineHero.astro';
import IssueCard from '@/components/IssueCard.astro';
import { site } from '@/lib/site';
import { siteIssues } from '@/data/issues';
import { getCurrentCoverEssay, getCoverEssayForIssue } from '@/lib/issues';
import { getPublishedFrameworks } from '@/lib/content';

const { issue, essay } = await getCurrentCoverEssay();
const shelf = await Promise.all(
  siteIssues.map(async (i) => ({
    issue: i,
    essay: await getCoverEssayForIssue(i),
  })),
);
const lexicon = (await getPublishedFrameworks()).slice(0, 4);
---

<BaseLayout description={site.description}>
  <div class="page-shell pb-8 pt-5 sm:pb-10 sm:pt-6">
    <div class="page-main space-y-10">
      <MagazineHero issue={issue} essay={essay} />

      <section class="issue-shelf-section" aria-label="All issues">
        <div class="section-kicker">
          <h2 class="folio">All Issues</h2>
          <a href="/issues/" class="link-editorial text-xs">Issue archive</a>
        </div>
        <div class="issue-shelf-grid">
          {
            shelf.map(({ issue: i, essay: e }) => (
              <IssueCard issue={i} essay={e} current={i.number === issue.number} />
            ))
          }
        </div>
      </section>

      <section class="section-block">
        <div class="section-kicker">
          <h2 class="folio">Lexicon</h2>
          <a href="/lexicon/" class="link-editorial text-xs">All entries</a>
        </div>
        <div class="mt-4 divide-y divide-line">
          {
            lexicon.map((entry) => (
              <article class="py-3">
                <a href={`/lexicon/${entry.slug}/`} class="group block">
                  <span class="font-mono text-[11px] uppercase tracking-wide text-accent-rust">
                    {entry.data.abbreviation}
                  </span>
                  <h3 class="mt-0.5 font-serif text-base font-semibold text-ink group-hover:text-forest">
                    {entry.data.title}
                  </h3>
                </a>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-block border-t border-line pt-6">
        <p class="folio">NLUCloud Press</p>
        <p class="mt-2 text-sm text-ink-muted">
          <a href="/annual-review/" class="link-editorial">
            AI &amp; Society Annual Review 2026
          </a>
          {' '}— forthcoming late 2026.
          <a href="/press/" class="link-editorial ml-2">Press</a>
          <a href="/masthead/" class="link-editorial ml-2">Masthead</a>
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .issue-shelf-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 1.25rem;
    margin-top: 1rem;
  }

  @media (min-width: 640px) {
    .issue-shelf-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem 1.5rem;
    }
  }
</style>
