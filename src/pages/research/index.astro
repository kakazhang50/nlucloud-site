---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ResearchListItem from '@/components/ResearchListItem.astro';
import { getResearchPapers } from '@/lib/content';
import { site } from '@/lib/site';

const papers = await getResearchPapers();
---

<BaseLayout
  title="Research"
  description={`Published research on SSRN — source papers behind ${site.magazineName} essays and lexicon entries.`}
  breadcrumbs={[{ name: 'Research', path: '/research/' }]}
>
  <div class="page-shell py-4 sm:py-5">
    <div class="page-main">
      <p class="folio mb-3">SSRN · {papers.length} papers</p>
      {papers.map((paper) => <ResearchListItem paper={paper} />)}
    </div>
  </div>
</BaseLayout>
