---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/lib/site';
import { getPublishedEditorNotes } from '@/lib/content';

const notes = await getPublishedEditorNotes();
---

<BaseLayout
  title="Editor's Notes"
  description="Editorial notes on the research program — synthesis, method, and evolving judgment."
  breadcrumbs={[{ name: "Editor's Notes", path: '/editors-notes/' }]}
>
  <div class="page-shell py-4 sm:py-5">
    <div class="page-main">
      <p class="folio mb-3">Editor's Notes</p>
      {
        notes.length > 0 ? (
          notes.map((note) => (
            <article class="feed-item">
              <h2 class="feed-title">
                <a href={`/editors-notes/${note.slug}/`}>{note.data.title}</a>
              </h2>
              <p class="mt-1.5 text-sm text-ink-muted">{note.data.description}</p>
              <p class="feed-meta">{formatDate(note.data.pubDate)}</p>
            </article>
          ))
        ) : (
          <p class="text-sm text-ink-muted">No notes published yet.</p>
        )
      }
    </div>
  </div>
</BaseLayout>
